<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SolvIt — Har Problem Ka Solution</title>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600;800&family=Noto+Sans+Devanagari:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --card: #13131a;
    --border: #2a2a3a;
    --accent: #ff6b35;
    --accent2: #ffd700;
    --text: #f0f0f5;
    --muted: #888899;
    --gradient: linear-gradient(135deg, #ff6b35, #ff3d7f, #ffd700);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Baloo 2', 'Noto Sans Devanagari', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Background pattern */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: 
      radial-gradient(ellipse at 20% 20%, rgba(255,107,53,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(255,61,127,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, rgba(255,215,0,0.04) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 16px;
    position: relative;
    z-index: 1;
  }

  /* Header */
  header {
    padding: 24px 0 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    background: var(--gradient);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    box-shadow: 0 4px 20px rgba(255,107,53,0.4);
  }

  .logo-text {
    font-size: 24px;
    font-weight: 800;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .plan-badge {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 6px 14px;
    font-size: 13px;
    color: var(--muted);
    cursor: pointer;
  }

  .plan-badge span {
    color: var(--accent2);
    font-weight: 600;
  }

  /* Hero */
  .hero {
    text-align: center;
    padding: 32px 0 24px;
  }

  .hero h1 {
    font-size: clamp(26px, 6vw, 40px);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 10px;
  }

  .hero h1 span {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    color: var(--muted);
    font-size: 15px;
    margin-bottom: 20px;
  }

  /* Usage counter */
  .usage-bar-wrap {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 30px;
    padding: 8px 16px;
    font-size: 13px;
    margin-bottom: 8px;
  }

  .usage-dots {
    display: flex;
    gap: 5px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border);
    transition: background 0.3s;
  }

  .dot.used { background: var(--accent); }

  /* Category Pills */
  .categories {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 24px;
  }

  .cat-pill {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 8px 14px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .cat-pill:hover, .cat-pill.active {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(255,107,53,0.08);
  }

  /* Input Area */
  .input-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 20px;
    margin-bottom: 20px;
    transition: border-color 0.3s;
  }

  .input-card:focus-within {
    border-color: rgba(255,107,53,0.5);
  }

  .input-label {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  textarea {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'Baloo 2', 'Noto Sans Devanagari', sans-serif;
    font-size: 16px;
    resize: none;
    min-height: 100px;
    line-height: 1.6;
  }

  textarea::placeholder { color: #444455; }

  .input-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }

  .lang-toggle {
    display: flex;
    gap: 6px;
  }

  .lang-btn {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 5px 12px;
    font-size: 12px;
    color: var(--muted);
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
  }

  .lang-btn.active {
    background: rgba(255,107,53,0.15);
    border-color: var(--accent);
    color: var(--accent);
  }

  .solve-btn {
    background: var(--gradient);
    border: none;
    border-radius: 12px;
    padding: 12px 24px;
    color: white;
    font-family: inherit;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: opacity 0.2s, transform 0.2s;
    box-shadow: 0 4px 20px rgba(255,107,53,0.35);
  }

  .solve-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .solve-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  /* Answer Card */
  .answer-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 24px;
    margin-bottom: 20px;
    display: none;
    animation: fadeUp 0.4s ease;
  }

  .answer-card.visible { display: block; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .answer-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .answer-icon {
    width: 36px;
    height: 36px;
    background: var(--gradient);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .answer-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--accent);
  }

  .answer-subtitle {
    font-size: 12px;
    color: var(--muted);
  }

  .answer-text {
    font-size: 15px;
    line-height: 1.8;
    color: var(--text);
    white-space: pre-wrap;
  }

  .answer-actions {
    display: flex;
    gap: 10px;
    margin-top: 18px;
    flex-wrap: wrap;
  }

  .action-btn {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 8px 16px;
    font-size: 13px;
    color: var(--muted);
    cursor: pointer;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.2s;
  }

  .action-btn:hover { border-color: var(--accent); color: var(--accent); }

  /* Loading */
  .loading {
    display: none;
    text-align: center;
    padding: 30px;
  }

  .loading.visible { display: block; }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 12px;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .loading p {
    color: var(--muted);
    font-size: 14px;
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse { 0%,100%{opacity:0.5} 50%{opacity:1} }

  /* Paywall */
  .paywall {
    display: none;
    background: var(--card);
    border: 1px solid rgba(255,215,0,0.3);
    border-radius: 20px;
    padding: 32px 24px;
    text-align: center;
    margin-bottom: 20px;
    animation: fadeUp 0.4s ease;
  }

  .paywall.visible { display: block; }

  .paywall-icon {
    font-size: 40px;
    margin-bottom: 12px;
  }

  .paywall h2 {
    font-size: 22px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .paywall p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .plans {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 20px;
  }

  .plan-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 14px;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
  }

  .plan-card:hover { border-color: var(--accent); }

  .plan-card.featured {
    border-color: var(--accent2);
    background: rgba(255,215,0,0.05);
  }

  .plan-badge-top {
    position: absolute;
    top: -10px;
    right: 12px;
    background: var(--accent2);
    color: #000;
    font-size: 10px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 10px;
  }

  .plan-name {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 4px;
  }

  .plan-price {
    font-size: 22px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .plan-price span {
    font-size: 13px;
    font-weight: 400;
    color: var(--muted);
  }

  .plan-features {
    list-style: none;
    font-size: 12px;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .plan-features li::before { content: "✓ "; color: var(--accent); }

  .subscribe-btn {
    width: 100%;
    background: var(--gradient);
    border: none;
    border-radius: 14px;
    padding: 16px;
    color: white;
    font-family: inherit;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(255,107,53,0.4);
    transition: opacity 0.2s;
  }

  .subscribe-btn:hover { opacity: 0.9; }

  /* History */
  .history-section {
    margin-bottom: 20px;
  }

  .section-title {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .history-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: border-color 0.2s;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .history-item:hover { border-color: var(--accent); }

  .history-cat {
    font-size: 18px;
    flex-shrink: 0;
  }

  .history-q {
    font-size: 14px;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .history-time {
    font-size: 11px;
    color: var(--muted);
    flex-shrink: 0;
  }

  /* Bottom nav hint */
  .bottom-hint {
    text-align: center;
    padding: 20px 0 32px;
    font-size: 12px;
    color: #333344;
  }
</style>
</head>
<body>
<div class="container">

  <!-- Header -->
  <header>
    <div class="logo">
      <div class="logo-icon">💡</div>
      <div class="logo-text">SolvIt</div>
    </div>
    <div class="plan-badge" onclick="showPaywall()">
      Free Plan · <span>Upgrade ↑</span>
    </div>
  </header>

  <!-- Hero -->
  <div class="hero">
    <h1>Koi bhi problem?<br><span>Solution milega!</span></h1>
    <p>Career • Paise • Rishte • Health • Tech — sab kuch</p>

    <div class="usage-bar-wrap">
      <div class="usage-dots">
        <div class="dot used" id="d1"></div>
        <div class="dot" id="d2"></div>
        <div class="dot" id="d3"></div>
      </div>
      <span id="usage-text" style="color: var(--muted);">Aaj 2 sawaal baaki hain (Free)</span>
    </div>
  </div>

  <!-- Categories -->
  <div class="categories">
    <div class="cat-pill active" onclick="setCategory(this, 'career')">💼 Career</div>
    <div class="cat-pill" onclick="setCategory(this, 'paise')">💰 Paise</div>
    <div class="cat-pill" onclick="setCategory(this, 'health')">❤️ Health</div>
    <div class="cat-pill" onclick="setCategory(this, 'rishte')">👥 Rishte</div>
    <div class="cat-pill" onclick="setCategory(this, 'tech')">📱 Tech</div>
    <div class="cat-pill" onclick="setCategory(this, 'general')">✨ Kuch bhi</div>
  </div>

  <!-- Input -->
  <div class="input-card">
    <div class="input-label">🤔 Apni problem likho (Hindi ya English mein)</div>
    <textarea id="problemInput" placeholder="Jaise: Meri job mein promotion nahi mil raha, kya karun?&#10;Or: I can't save money, please help me..."></textarea>
    <div class="input-footer">
      <div class="lang-toggle">
        <button class="lang-btn" onclick="setLang('hindi', this)">🇮🇳 Hindi</button>
        <button class="lang-btn active" onclick="setLang('both', this)">🌐 Both</button>
        <button class="lang-btn" onclick="setLang('english', this)">🇺🇸 English</button>
      </div>
      <button class="solve-btn" id="solveBtn" onclick="solveProblem()">
        ⚡ Solve Karo
      </button>
    </div>
  </div>

  <!-- Loading -->
  <div class="loading" id="loading">
    <div class="spinner"></div>
    <p id="loadingText">AI soch raha hai... 🤔</p>
  </div>

  <!-- Answer -->
  <div class="answer-card" id="answerCard">
    <div class="answer-header">
      <div class="answer-icon">🎯</div>
      <div>
        <div class="answer-title">SolvIt AI ka Jawab</div>
        <div class="answer-subtitle" id="answerMeta">Abhi generate hua</div>
      </div>
    </div>
    <div class="answer-text" id="answerText"></div>
    <div class="answer-actions">
      <button class="action-btn" onclick="copyAnswer()">📋 Copy</button>
      <button class="action-btn" onclick="askFollowUp()">💬 Aur poochho</button>
      <button class="action-btn" onclick="shareAnswer()">🔗 Share</button>
    </div>
  </div>

  <!-- Paywall -->
  <div class="paywall" id="paywall">
    <div class="paywall-icon">🔒</div>
    <h2>Free limit khatam! 😅</h2>
    <p>Aaj ke 3 free sawaal ho gaye. Unlimited solutions ke liye upgrade karo — career, paise, health, sab mein expert AI help milegi!</p>
    
    <div class="plans">
      <div class="plan-card" onclick="selectPlan('basic')">
        <div class="plan-name">Basic</div>
        <div class="plan-price">₹99 <span>/month</span></div>
        <ul class="plan-features">
          <li>Unlimited questions</li>
          <li>Hindi + English</li>
          <li>All categories</li>
        </ul>
      </div>
      <div class="plan-card featured" onclick="selectPlan('premium')">
        <div class="plan-badge-top">🔥 Best</div>
        <div class="plan-name">Premium</div>
        <div class="plan-price">₹299 <span>/month</span></div>
        <ul class="plan-features">
          <li>Unlimited questions</li>
          <li>Expert consultation</li>
          <li>Priority AI</li>
          <li>PDF save karo</li>
        </ul>
      </div>
    </div>

    <button class="subscribe-btn" onclick="handleSubscribe()">
      🚀 Abhi Subscribe Karo
    </button>
    <p style="margin-top:12px; font-size:12px; color: var(--muted);">Cancel anytime • Secure payment</p>
  </div>

  <!-- History -->
  <div class="history-section" id="historySection" style="display:none;">
    <div class="section-title">Purane Sawaal</div>
    <div id="historyList"></div>
  </div>

  <div class="bottom-hint">Powered by SolvIt AI • Made with ❤️ in India</div>
</div>

<script>
  let selectedCategory = 'career';
  let selectedLang = 'both';
  let questionsUsed = 1;
  const FREE_LIMIT = 3;
  let questionHistory = [];
  let lastAnswer = '';

  const loadingMessages = [
    "AI soch raha hai... 🤔",
    "Problem analyze ho rahi hai...",
    "Best solution dhoondha ja raha hai...",
    "Bilkul ready hone wala hai! ✨"
  ];

  function setCategory(el, cat) {
    document.querySelectorAll('.cat-pill').forEach(p => p.classList.remove('active'));
    el.classList.add('active');
    selectedCategory = cat;
  }

  function setLang(lang, el) {
    document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
    selectedLang = lang;
  }

  function updateUsageUI() {
    const dots = ['d1','d2','d3'];
    dots.forEach((id, i) => {
      document.getElementById(id).classList.toggle('used', i < questionsUsed);
    });
    const remaining = FREE_LIMIT - questionsUsed;
    document.getElementById('usage-text').textContent = 
      remaining > 0 
        ? `Aaj ${remaining} sawaal baaki hain (Free)`
        : `Free limit khatam — Upgrade karo!`;
  }

  async function solveProblem() {
    const problem = document.getElementById('problemInput').value.trim();
    if (!problem) {
      document.getElementById('problemInput').style.borderBottom = '2px solid var(--accent)';
      document.getElementById('problemInput').placeholder = 'Pehle problem likho! 😊';
      return;
    }

    if (questionsUsed >= FREE_LIMIT) {
      showPaywall();
      return;
    }

    // Hide previous, show loading
    document.getElementById('answerCard').classList.remove('visible');
    document.getElementById('paywall').classList.remove('visible');
    document.getElementById('loading').classList.add('visible');
    document.getElementById('solveBtn').disabled = true;

    // Animate loading messages
    let msgIdx = 0;
    const msgInterval = setInterval(() => {
      msgIdx = (msgIdx + 1) % loadingMessages.length;
      document.getElementById('loadingText').textContent = loadingMessages[msgIdx];
    }, 1500);

    const langInstruction = selectedLang === 'hindi' 
      ? 'Sirf Hindi mein jawab do.'
      : selectedLang === 'english' 
        ? 'Answer only in English.'
        : 'Answer in a mix of Hindi and English (Hinglish). Use Hindi for warmth and English for key terms.';

    const systemPrompt = `You are SolvIt — a friendly, practical Indian AI life advisor. You solve real problems that everyday Indian people face. 

${langInstruction}

Category: ${selectedCategory}

Rules:
- Be warm, empathetic, and direct
- Give 3-5 actionable steps
- Use simple language, avoid jargon  
- Be realistic about Indian context (money, culture, family dynamics)
- Keep response concise but complete (200-300 words max)
- Use emojis naturally to make it friendly
- Format with clear numbered steps`;

    try {
      const GEMINI_KEY = "AIzaSyDt9d8wBE9Hj5RnUXRtlPQ5G4PRW9AifSU"
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${GEMINI_KEY}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          contents: [{
            parts: [{ text: systemPrompt + "\n\nUser problem: " + problem }]
          }]
        })
      });

      const data = await response.json();
      const answer = data.candidates?.[0]?.content?.parts?.[0]?.text || "Kuch gadbad ho gayi. Dobara try karo!";

      clearInterval(msgInterval);
      document.getElementById('loading').classList.remove('visible');
      document.getElementById('solveBtn').disabled = false;

      // Show answer
      lastAnswer = answer;
      document.getElementById('answerText').textContent = answer;
      document.getElementById('answerMeta').textContent = `${selectedCategory} • ${new Date().toLocaleTimeString('hi-IN')}`;
      document.getElementById('answerCard').classList.add('visible');

      // Update usage
      questionsUsed++;
      updateUsageUI();

      // Save to history
      questionHistory.unshift({ q: problem, cat: selectedCategory, time: 'Abhi' });
      renderHistory();

    } catch (err) {
      clearInterval(msgInterval);
      document.getElementById('loading').classList.remove('visible');
      document.getElementById('solveBtn').disabled = false;
      document.getElementById('answerText').textContent = "❌ Network error. Internet connection check karo aur dobara try karo.";
      document.getElementById('answerCard').classList.add('visible');
    }
  }

  function showPaywall() {
    document.getElementById('answerCard').classList.remove('visible');
    document.getElementById('paywall').classList.add('visible');
    document.getElementById('paywall').scrollIntoView({ behavior: 'smooth' });
  }

  function selectPlan(plan) {
    document.querySelectorAll('.plan-card').forEach(c => c.style.transform = 'scale(1)');
    event.currentTarget.style.transform = 'scale(1.03)';
  }

  function handleSubscribe() {
    alert('🚀 Payment gateway integrate hoga!\n\nAbhi ye prototype hai. Real app mein Razorpay/Stripe se payment hogi.\n\nThank you for interest! 💛');
  }

  function copyAnswer() {
    navigator.clipboard.writeText(lastAnswer).then(() => {
      const btn = event.currentTarget;
      btn.textContent = '✅ Copied!';
      setTimeout(() => btn.textContent = '📋 Copy', 2000);
    });
  }

  function askFollowUp() {
    document.getElementById('problemInput').focus();
    document.getElementById('problemInput').value = '';
    document.getElementById('problemInput').placeholder = 'Aur kya jaanna chahte ho iske baare mein?';
  }

  function shareAnswer() {
    if (navigator.share) {
      navigator.share({ title: 'SolvIt Answer', text: lastAnswer });
    } else {
      copyAnswer();
    }
  }

  function renderHistory() {
    const catEmoji = { career:'💼', paise:'💰', health:'❤️', rishte:'👥', tech:'📱', general:'✨' };
    const sec = document.getElementById('historySection');
    const list = document.getElementById('historyList');
    
    if (questionHistory.length === 0) { sec.style.display = 'none'; return; }
    sec.style.display = 'block';

    list.innerHTML = questionHistory.slice(0, 3).map(h => `
      <div class="history-item">
        <span class="history-cat">${catEmoji[h.cat] || '✨'}</span>
        <span class="history-q">${h.q}</span>
        <span class="history-time">${h.time}</span>
      </div>
    `).join('');
  }

  // Init
  updateUsageUI();

  // Enter key shortcut
  document.getElementById('problemInput').addEventListener('keydown', function(e) {
    if (e.ctrlKey && e.key === 'Enter') solveProblem();
  });
</script>
</body>
</html>
